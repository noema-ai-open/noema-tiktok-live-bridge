# The HTTP server always binds to 127.0.0.1.
NOEMA_PORT=8765
NOEMA_MODE=mock
NOEMA_MOCK_EVENTS_PER_SECOND=1.0
NOEMA_DATABASE_PATH=./noema_bridge.sqlite3
NOEMA_RING_BUFFER_SIZE=500
NOEMA_DEDUPE_WINDOW_SECONDS=30
NOEMA_TTS_ENGINE=sapi

# Live mode (TikTokLive is an unofficial optional dependency: install .[live]).
NOEMA_TIKTOK_USERNAME=
NOEMA_EULERSTREAM_API_KEY=
NOEMA_LIVE_OFFLINE_POLL_SECONDS=60

# Optional OpenAI-compatible TTS provider. Secrets stay in this local .env file.
EXTERNAL_TTS_API_KEY=
EXTERNAL_TTS_BASE_URL=
EXTERNAL_TTS_MODEL=tts-1
# Required for non-WAV audio (and for all formats outside Windows).
EXTERNAL_TTS_PLAYER_COMMAND=
